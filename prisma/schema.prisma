// Orochat Database Schema
// PostgreSQL with Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model - Core user account
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String    // Hashed with bcrypt
  name          String
  username      String?   @unique // Public @handle, shown on the Global feed
  bio           String?
  avatar        String?
  title         String?   // Professional title
  company       String?
  location      String?   // City, Country format
  countryCode   String?   // ISO 3166-1 alpha-2, used for the Global feed flag badge
  qualifications String?  // JSON array of qualifications
  workHistory    String?  // JSON array of work history entries
  education      String?  // JSON array of education entries (institution, city, country, yearCompleted)
  
  // Qualification & Status
  isPartner     Boolean   @default(false) // Orochat Partner status
  isPaused      Boolean   @default(false) // Orochat account paused status
  qualifiedAt   DateTime? // When they achieved qualification
  
  // Qualification Metrics
  verifiedOrosCount Int @default(0) // Cached count of verified connections
  compassMembershipsCount Int @default(0) // Cached count of Compass communities
  
  // TES (Total Engagement Score)
  currentTES    Float     @default(0)
  lastTESUpdate DateTime? @default(now())

  // Stripe Connect Express — payout account for Oro revenue-share distributions
  stripeConnectAccountId        String?  @unique
  stripeConnectOnboarded        Boolean  @default(false) // charges_enabled && payouts_enabled per Stripe account.updated
  stripeConnectDetailsSubmitted Boolean  @default(false) // onboarding form completed, even if not yet fully verified

  // Presence — raw client-reported status; lib/presence.ts resolves the
  // real-time value, forcing "offline" once lastSeenAt goes stale
  presenceStatus String    @default("offline")
  lastSeenAt     DateTime?

  // Semantic search: USE (Universal Sentence Encoder) embedding of
  // title + company + bio + location, recomputed on every profile edit.
  embedding     Float[]   @default([])
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  sentConnections     Connection[] @relation("ConnectionSender")
  receivedConnections Connection[] @relation("ConnectionReceiver")
  sentMessages        Message[] @relation("MessageSender")
  conversations       ConversationParticipant[]
  compassMemberships  CompassMembership[]
  compassCommunities  Compass[] @relation("CompassCreator")
  feedPosts           FeedPost[]
  tesLogs             TESLog[]
  passwordResetTokens PasswordResetToken[]
  revenueDistributions RevenueDistribution[]
  postLikes           PostLike[]
  postComments        PostComment[]
  fraudFlags          FraudFlag[]
  initiatedCalls      CallSession[] @relation("CallInitiator")
  ownedNests          Nest[] @relation("NestOwner")
  nestMemberships     NestMember[] @relation("NestMembership")
  assignedNestTasks   NestTask[] @relation("NestTaskAssignee")
  createdNestTasks    NestTask[] @relation("NestTaskCreator")
  initiatedAgreements Agreement[] @relation("AgreementInitiator")
  agreementSignatures AgreementSigner[]

  @@index([email])
  @@index([isPartner])
}

// Connection Model - Oros (verified professional connections)
model Connection {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  status      ConnectionStatus @default(PENDING)
  verifiedAt  DateTime? // When connection was verified/accepted
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  sender      User @relation("ConnectionSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  
  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

// Compass Model - Professional communities
model Compass {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  image       String?
  
  // Only Orochat Partners can create/moderate
  creatorId   String
  creator     User @relation("CompassCreator", fields: [creatorId], references: [id])
  
  // Sponsorship (B2B Advertising)
  isSponsored Boolean  @default(false)
  sponsorName String?
  sponsorLogo String?
  sponsorLink String?
  sponsorExpiresAt DateTime?

  // USE embedding of name + description, recomputed on create — used to
  // score ad-campaign relevance (see lib/ai/compassEmbedding.ts)
  embedding   Float[]  @default([])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships  CompassMembership[]
  posts        FeedPost[]
  conversation Conversation?

  @@index([slug])
  @@index([creatorId])
}

// Compass Membership - User's membership in communities
model CompassMembership {
  id        String   @id @default(cuid())
  userId    String
  compassId String
  role      CompassRole @default(MEMBER)
  
  joinedAt  DateTime @default(now())
  
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  compass   Compass @relation(fields: [compassId], references: [id], onDelete: Cascade)
  
  @@unique([userId, compassId])
  @@index([userId])
  @@index([compassId])
}

enum CompassRole {
  MEMBER
  MODERATOR
  ADMIN
}

// Conversation Model - Collab Tool chat thread (1:1 or group)
model Conversation {
  id        String   @id @default(cuid())
  isGroup   Boolean  @default(false)
  name      String?  // group display name; null for 1:1 chats
  compassId String?  @unique // set when this is a Compass community's auto-created group chat

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  compass      Compass?                  @relation(fields: [compassId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]
  callSessions CallSession[]
  agreements   Agreement[]
  nest         Nest?

  @@index([updatedAt])
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime? // messages with createdAt after this are "unread" for this participant

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

// Message Model - Collab Tool messages
model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String

  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// Call Session Model - tracks Collab video calls for history + duration enforcement
model CallSession {
  id              String    @id @default(cuid())
  conversationId  String
  roomName        String    @unique
  initiatorId     String
  messageId       String?   @unique // the "Join Meeting" chat message announcing this call
  durationSeconds Int?      // null = no limit
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  archived        Boolean   @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  initiator    User         @relation("CallInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)

  @@index([conversationId, startedAt])
}

// Multi-party cryptographic agreement — a relational source of truth (same
// pattern as CallSession above) instead of encoding signer state into chat
// message text. The initiator signs at drafting time (stored inline here);
// each other required party gets its own AgreementSigner row.
model Agreement {
  id                 String          @id @default(cuid())
  conversationId     String
  title              String
  terms              String
  initiatorId        String
  initiatorKey       Json
  initiatorSignature String
  messageId          String?         @unique // the chat message announcing this agreement
  status             AgreementStatus @default(PENDING)
  createdAt          DateTime        @default(now())

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  initiator    User              @relation("AgreementInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  signers      AgreementSigner[]

  @@index([conversationId])
}

enum AgreementStatus {
  PENDING
  EXECUTED
}

model AgreementSigner {
  id           String    @id @default(cuid())
  agreementId  String
  userId       String
  publicKeyJwk Json?
  signature    String?
  signedAt     DateTime?

  agreement Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agreementId, userId])
}

// OroNest - project workspaces (task board + notes + a reused group chat for messaging/calls)
model Nest {
  id             String    @id @default(cuid())
  name           String
  ownerId        String
  conversationId String    @unique
  archived       Boolean   @default(false)
  expiresAt      DateTime? // null = no time limit
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  owner        User         @relation("NestOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  members      NestMember[]
  tasks        NestTask[]
  notes        NestNote[]

  @@index([ownerId])
}

model NestMember {
  id       String   @id @default(cuid())
  nestId   String
  userId   String
  joinedAt DateTime @default(now())

  nest Nest @relation(fields: [nestId], references: [id], onDelete: Cascade)
  user User @relation("NestMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([nestId, userId])
  @@index([userId])
}

enum NestTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model NestTask {
  id          String         @id @default(cuid())
  nestId      String
  title       String
  description String?
  status      NestTaskStatus @default(TODO)
  assigneeId  String?
  dueDate     DateTime?
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  nest     Nest  @relation(fields: [nestId], references: [id], onDelete: Cascade)
  assignee User? @relation("NestTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator  User  @relation("NestTaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([nestId, status])
}

model NestNote {
  id          String   @id @default(cuid())
  nestId      String
  content     String   // Tiptap HTML
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?

  nest Nest @relation(fields: [nestId], references: [id], onDelete: Cascade)

  @@index([nestId, createdAt])
}

// Feed Post Model - Activity feed posts
model FeedPost {
  id          String   @id @default(cuid())
  authorId    String
  compassId   String?  // If posted in a Compass community
  content     String
  imageUrl    String?
  visibility  PostVisibility @default(PRIVATE) // PUBLIC posts appear on the Global feed
  archived    Boolean  @default(false) // Hidden from feeds but kept for the author

  likesCount  Int      @default(0)
  commentsCount Int    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  compass     Compass? @relation(fields: [compassId], references: [id], onDelete: SetNull)
  likes       PostLike[]
  comments    PostComment[]

  @@index([authorId])
  @@index([compassId])
  @@index([createdAt])
  @@index([visibility, createdAt])
}

enum PostVisibility {
  PRIVATE // Visible to Oros + Compass members only
  PUBLIC  // Also visible on the Global feed
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([postId])
  @@index([userId])
}

// TES Log Model - Track TES changes for revenue distribution
model TESLog {
  id          String   @id @default(cuid())
  userId      String
  tesValue    Float
  changeReason String  // e.g., "Collab usage", "Feed activity"
  
  createdAt   DateTime @default(now())
  
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt])
}

// Password Reset Token Model
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// Ad Revenue Pool Model - Monthly revenue distribution pool
model AdRevenuePool {
  id          String   @id @default(cuid())
  month       Int      // 1-12
  year        Int
  totalAmount Float    // Oro-payable pool = grossAmount * PlatformConfig.oroSharePercent at creation time
  grossAmount Float?    // Total ad revenue collected this period, before the platform cut
  platformCutAmount Float? // grossAmount - totalAmount, retained by Orochat
  distributed Boolean  @default(false)
  distributedAt DateTime?
  
  createdAt   DateTime @default(now())
  
  distributions RevenueDistribution[]

  @@unique([month, year])
  @@index([year, month])
}

// Revenue Distribution Model - Individual user payouts
model RevenueDistribution {
  id          String   @id @default(cuid())
  poolId      String
  userId      String
  tesShare    Float    // User's TES contribution to total pool TES
  amount      Float    // Calculated payout amount
  paid        Boolean  @default(false)
  paidAt      DateTime?

  // Stripe Connect transfer tracking — set when a real money-movement
  // attempt is made (initial batch distribution or manual retry)
  stripeTransferId    String?      @unique
  payoutStatus        PayoutStatus @default(PENDING)
  payoutFailureReason String?
  payoutAttemptedAt   DateTime?

  createdAt   DateTime @default(now())

  pool      AdRevenuePool @relation(fields: [poolId], references: [id])
  user      User @relation(fields: [userId], references: [id])

  @@index([poolId])
  @@index([userId])
  @@index([paid])
  @@index([payoutStatus])
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
  NOT_CONNECTED
}

// Fraud Flag Model - Records suspicious connection-graph patterns
// (sybil-like cliques, connection-farming bursts) found before a revenue
// payout, so flagged partners are excluded from that round's distribution.
model FraudFlag {
  id        String   @id @default(cuid())
  userId    String
  riskScore Float
  reason    String
  resolved  Boolean  @default(false)

  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resolved])
}

// Admin account — fully isolated from the consumer User table/session.
// Authenticated via a separate NextAuth instance (lib/auth.admin.ts) so a
// compromised consumer session can never grant admin access.
model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String    // bcrypt, same approach as User.password
  name      String
  role      AdminRole @default(ADMIN)

  createdAt DateTime  @default(now())

  auditLogs AdminAuditLog[]
}

// Audit trail of admin actions — who did what, when, to what.
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // e.g. "user.pause", "campaign.status_change"
  targetType String?
  targetId   String?
  metadata   Json?

  createdAt  DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([createdAt])
  @@index([adminId])
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

// Singleton row (id always "singleton") holding admin-editable platform
// settings — currently just the ad-revenue split between Oros and Orochat.
model PlatformConfig {
  id              String   @id @default("singleton")
  oroSharePercent Float    @default(0.65) // 0-1; Oros' share of gross ad revenue

  updatedAt       DateTime @updatedAt
}

// Ad campaign — creative + manual community targeting. Serving (placing
// these into the Global/Compass feeds) is a separate follow-up; this is
// campaign management only.
model AdCampaign {
  id               String           @id @default(cuid())
  advertiserName   String
  headline         String
  body             String
  imageUrl         String?
  ctaLabel         String
  ctaUrl           String
  status           AdCampaignStatus @default(DRAFT)
  startAt          DateTime
  endAt            DateTime
  targetGlobal     Boolean          @default(true)
  targetCompassIds String[]         @default([]) // empty = no manual Compass targeting restriction
  targetKeywords   String?          // free-text topics; embedded into targetEmbedding for relevance scoring
  targetEmbedding  Float[]          @default([])

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  impressions AdImpression[]
  clicks      AdClick[]

  @@index([status])
}

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

model AdImpression {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  compassId  String?  // null = shown on Global/User feed
  createdAt  DateTime @default(now())

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
}

model AdClick {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  compassId  String?
  createdAt  DateTime @default(now())

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
}

